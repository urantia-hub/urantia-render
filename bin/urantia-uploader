#!/usr/bin/env bash
# UrantiaHub auto-uploader control script.
#
# Runs the orchestrator as a detached background process (nohup). Survives
# log-out, but NOT a reboot — after rebooting, run `./bin/urantia-uploader start`
# once to resume. Everything else (progress, quota, render state) persists.
#
# Commands:
#   start    — launch orchestrator in the background
#   stop     — kill the running orchestrator
#   restart  — stop + start
#   pause    — create PAUSED marker (daemon keeps running but skips uploads)
#   resume   — remove PAUSED marker
#   status   — show running state, progress, quota, last log lines
#   log      — tail -f the orchestrator log
#   next     — show which paper is up next + queue
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ORCHESTRATOR="$ROOT/youtube-sync/orchestrator.py"
SYNC_DIR="$ROOT/youtube-sync"
PAUSED="$SYNC_DIR/PAUSED"
LOG="$SYNC_DIR/orchestrator.log"
NOHUP_LOG="$SYNC_DIR/nohup.log"
PID_FILE="$SYNC_DIR/orchestrator.pid"
UPLOAD_STATE="$SYNC_DIR/upload-state.json"
QUOTA_LOG="$SYNC_DIR/quota-log.json"

is_running() {
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

cmd_start() {
    if is_running; then
        echo "already running (pid $(cat "$PID_FILE"))"
        return 0
    fi
    cd "$ROOT"
    # nohup so the process survives this shell exiting.
    # < /dev/null so uv/python don't see a TTY + hang.
    nohup "$ORCHESTRATOR" < /dev/null >> "$NOHUP_LOG" 2>&1 &
    PID=$!
    echo "$PID" > "$PID_FILE"
    echo "started (pid $PID)"
    echo "logs: $LOG"
    echo "check: $0 status   ·   tail: $0 log"
}

cmd_stop() {
    if [ ! -f "$PID_FILE" ]; then
        echo "(no pid file — not running)"
        return 0
    fi
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        # Kill orchestrator AND any child process (cargo/ffmpeg render).
        # Negative PID signals the whole process group.
        kill -TERM -"$PID" 2>/dev/null || kill -TERM "$PID" 2>/dev/null || true
        sleep 2
        if kill -0 "$PID" 2>/dev/null; then
            kill -KILL "$PID" 2>/dev/null || true
        fi
        echo "stopped (pid $PID)"
    else
        echo "(pid $PID not running — cleaning up stale pid file)"
    fi
    rm -f "$PID_FILE"
}

cmd_restart() {
    cmd_stop || true
    sleep 1
    cmd_start
}

cmd_pause() {
    touch "$PAUSED"
    echo "paused (marker: $PAUSED). daemon keeps running but skips uploads."
}

cmd_resume() {
    rm -f "$PAUSED"
    echo "resumed"
}

cmd_status() {
    echo "=== process state ==="
    if is_running; then
        PID=$(cat "$PID_FILE")
        echo "running (pid $PID)"
        ps -p "$PID" -o pid,etime,command 2>/dev/null | tail -1 || true
    else
        echo "not running  —  start with: $0 start"
    fi

    echo ""
    echo "=== pause state ==="
    if [ -f "$PAUSED" ]; then
        echo "PAUSED"
    else
        echo "running (no pause marker)"
    fi

    echo ""
    echo "=== progress ==="
    if [ -f "$UPLOAD_STATE" ]; then
        uploaded=$(python3 -c "import json; print(len(json.load(open('$UPLOAD_STATE'))))")
        echo "$uploaded / 197 papers uploaded"
    else
        echo "0 / 197 papers uploaded"
    fi

    echo ""
    echo "=== today's quota ==="
    if [ -f "$QUOTA_LOG" ]; then
        python3 -c "
import json
from datetime import datetime, timezone, timedelta
q = json.load(open('$QUOTA_LOG'))
today = (datetime.now(timezone.utc) - timedelta(hours=8)).strftime('%Y-%m-%d')
used = q.get(today, 0)
print(f'used {used}/8500 units today ({used / 1750:.1f} uploads)')
" 2>/dev/null || echo "(quota log unreadable)"
    else
        echo "0 units used today"
    fi

    echo ""
    echo "=== last 10 log lines ==="
    if [ -f "$LOG" ]; then
        tail -10 "$LOG"
    else
        echo "(no log yet — waiting for first iteration)"
    fi
}

cmd_log() {
    touch "$LOG"
    tail -f "$LOG"
}

cmd_next() {
    python3 <<PY
import json
from pathlib import Path

state_path = Path("$UPLOAD_STATE")
done = json.loads(state_path.read_text()) if state_path.exists() else {}

remaining = [str(i) for i in range(197) if str(i) not in done]
if not remaining:
    print("all 197 papers uploaded")
else:
    print(f"next up: paper {remaining[0]}")
    print(f"queue (next 10): {', '.join(remaining[:10])}{'…' if len(remaining) > 10 else ''}")
    print(f"{len(remaining)} papers remaining")
PY
}

case "${1:-}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    pause)   cmd_pause ;;
    resume)  cmd_resume ;;
    status)  cmd_status ;;
    log)     cmd_log ;;
    next)    cmd_next ;;
    "")
        echo "usage: $0 {start|stop|restart|pause|resume|status|log|next}"
        exit 1
        ;;
    *)
        echo "unknown command: $1"
        echo "usage: $0 {start|stop|restart|pause|resume|status|log|next}"
        exit 1
        ;;
esac
