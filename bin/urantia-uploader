#!/usr/bin/env bash
# UrantiaHub auto-uploader control script.
#
# Wraps launchd so the orchestrator daemon runs continuously in the background,
# survives system restarts, and auto-restarts on crash.
#
# Commands:
#   start    — install + load the launchd agent; daemon starts running
#   stop     — unload + uninstall the launchd agent; daemon stops
#   pause    — create the PAUSED marker; daemon keeps running but stops uploading
#   resume   — remove the PAUSED marker; daemon resumes uploading
#   status   — show launchd state, last log lines, upload progress, quota
#   log      — tail -f the orchestrator log
#   next     — show which paper is up next + what's queued today
#   restart  — stop + start
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LABEL="com.urantia.uploader"
PLIST_DST="$HOME/Library/LaunchAgents/${LABEL}.plist"
PLIST_SRC="$ROOT/youtube-sync/com.urantia.uploader.plist.template"
ORCHESTRATOR="$ROOT/youtube-sync/orchestrator.py"
SYNC_DIR="$ROOT/youtube-sync"
PAUSED="$SYNC_DIR/PAUSED"
LOG="$SYNC_DIR/orchestrator.log"
UPLOAD_STATE="$SYNC_DIR/upload-state.json"
QUOTA_LOG="$SYNC_DIR/quota-log.json"

DOMAIN="gui/$(id -u)"
SERVICE="$DOMAIN/$LABEL"

install_plist() {
    mkdir -p "$(dirname "$PLIST_DST")"
    # Substitute current PATH, HOME, shell, and paths into the template.
    sed -e "s|{{ROOT}}|$ROOT|g" \
        -e "s|{{ORCHESTRATOR}}|$ORCHESTRATOR|g" \
        -e "s|{{SHELL}}|${SHELL:-/bin/bash}|g" \
        -e "s|{{PATH}}|$PATH|g" \
        -e "s|{{HOME}}|$HOME|g" \
        "$PLIST_SRC" > "$PLIST_DST"
}

cmd_start() {
    install_plist
    if launchctl print "$SERVICE" >/dev/null 2>&1; then
        echo "already loaded; bumping it"
        launchctl bootout "$SERVICE" 2>/dev/null || true
        sleep 1
    fi
    launchctl bootstrap "$DOMAIN" "$PLIST_DST"
    launchctl enable "$SERVICE"
    echo "started. tail the log with:  $0 log"
}

cmd_stop() {
    launchctl bootout "$SERVICE" 2>/dev/null || echo "(already stopped)"
    rm -f "$PLIST_DST"
    echo "stopped + uninstalled"
}

cmd_pause() {
    touch "$PAUSED"
    echo "paused. daemon will skip uploads until you run: $0 resume"
}

cmd_resume() {
    rm -f "$PAUSED"
    echo "resumed"
}

cmd_status() {
    echo "=== launchd state ==="
    if launchctl print "$SERVICE" >/dev/null 2>&1; then
        launchctl print "$SERVICE" | grep -E "state|pid|last exit|last launched|path" | head -10 || true
    else
        echo "(not loaded — run: $0 start)"
    fi

    echo ""
    echo "=== pause state ==="
    if [ -f "$PAUSED" ]; then
        echo "PAUSED"
    else
        echo "running"
    fi

    echo ""
    echo "=== progress ==="
    if [ -f "$UPLOAD_STATE" ]; then
        uploaded=$(python3 -c "import json; print(len(json.load(open('$UPLOAD_STATE'))))")
        echo "$uploaded / 197 papers uploaded"
    else
        echo "0 / 197 papers uploaded (no state file yet)"
    fi

    echo ""
    echo "=== today's quota ==="
    if [ -f "$QUOTA_LOG" ]; then
        python3 -c "
import json
from datetime import datetime, timezone, timedelta
q = json.load(open('$QUOTA_LOG'))
today = (datetime.now(timezone.utc) - timedelta(hours=8)).strftime('%Y-%m-%d')
used = q.get(today, 0)
print(f'used {used}/8500 units today ({used / 1750:.1f} uploads)')
" 2>/dev/null || echo "(quota log unreadable)"
    else
        echo "0 units used today"
    fi

    echo ""
    echo "=== last 10 log lines ==="
    if [ -f "$LOG" ]; then
        tail -10 "$LOG"
    else
        echo "(no log yet)"
    fi
}

cmd_log() {
    touch "$LOG"
    tail -f "$LOG"
}

cmd_next() {
    python3 <<PY
import json
from pathlib import Path

state_path = Path("$UPLOAD_STATE")
done = json.loads(state_path.read_text()) if state_path.exists() else {}

remaining = [str(i) for i in range(197) if str(i) not in done]
if not remaining:
    print("all 197 papers uploaded")
else:
    print(f"next up: paper {remaining[0]}")
    print(f"queue (next 10): {', '.join(remaining[:10])}{'…' if len(remaining) > 10 else ''}")
    print(f"{len(remaining)} papers remaining")
PY
}

cmd_restart() {
    cmd_stop || true
    sleep 1
    cmd_start
}

case "${1:-}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    pause)   cmd_pause ;;
    resume)  cmd_resume ;;
    status)  cmd_status ;;
    log)     cmd_log ;;
    next)    cmd_next ;;
    restart) cmd_restart ;;
    "")
        echo "usage: $0 {start|stop|pause|resume|status|log|next|restart}"
        exit 1
        ;;
    *)
        echo "unknown command: $1"
        echo "usage: $0 {start|stop|pause|resume|status|log|next|restart}"
        exit 1
        ;;
esac
